<?xml version="1.0"?>
<clickhouse>
  <!--
    Server file/console logging off (level none). Avoids disk/json-log growth from CH.
    Query/system metrics still go to *_log tables unless you disable those separately.
  -->
  <logger>
    <level>none</level>
    <log>/dev/null</log>
    <errorlog>/dev/null</errorlog>
    <console>false</console>
  </logger>
</clickhouse>
