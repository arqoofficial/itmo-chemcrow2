# =============================================================================
# ChemCrow2 — Environment Configuration
# =============================================================================
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env
#
# Для ЛОКАЛЬНОЙ разработки (с Docker и без) значения по умолчанию уже подходят.
# Для PRODUCTION — замени помеченные строки на реальные данные.
# =============================================================================

# -- Общее --
PROJECT_NAME="ChemCrow2"
STACK_NAME=chemcrow2

# local | staging | production
ENVIRONMENT=local

# -- Домен и фронтенд --
# Локально: localhost
# Production: IP сервера или домен (например, 123.45.67.89)
DOMAIN=localhost

# Локально: http://localhost:5173 (Docker) или http://localhost:5173 (Vite dev)
# Production: http://<IP_СЕРВЕРА>
FRONTEND_HOST=http://localhost:5173

# -- CORS --
# Локально: все localhost-ы
# Production: http://<IP_СЕРВЕРА>
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:8000"

# -- Безопасность --
# Сгенерируй: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change_me

# -- PostgreSQL --
# Без Docker: localhost
# С Docker: не важно, compose переопределяет на "db"
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# -- Redis --
# Без Docker: localhost
# С Docker: не важно, compose переопределяет на "redis://redis:6379/0"
REDIS_URL=redis://localhost:6379/0

# -- Email (опционально) --
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# -- Мониторинг (опционально) --
SENTRY_DSN=

# -- LLM / AI Agent --
# Провайдер по умолчанию: openai | anthropic
DEFAULT_LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
# Кастомный base URL (для совместимых прокси, Azure и т.д.). Оставь пустым для api.openai.com
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Кастомный base URL. Оставь пустым для api.anthropic.com
ANTHROPIC_BASE_URL=

# -- AI Agent: Optional Tool API Keys --
SERP_API_KEY=
CHEMSPACE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# -- Retrosynthesis service --
RETROSYNTHESIS_URL=http://localhost:8052
RETROSYNTHESIS_TIMEOUT=150

# -- AiZynthFinder --
AZF_CONFIG_PATH=data/aizynthfinder/config.yml

# -- Docker-образы --
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# -- Langfuse трассировка (опционально) --
# Задай ключи сам — Langfuse создаст проект автоматически при старте.
# Сгенерируй: python3 -c "import secrets; print('sk-lf-' + secrets.token_hex(24))"
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://langfuse-server:3000

# Автоматическая инициализация проекта при первом запуске
LANGFUSE_INIT_ORG_ID=my-org
LANGFUSE_INIT_ORG_NAME=ChemCrow
LANGFUSE_INIT_PROJECT_ID=chemcrow-agent
LANGFUSE_INIT_PROJECT_NAME=ChemCrow Agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=  # совпадает с LANGFUSE_PUBLIC_KEY
LANGFUSE_INIT_PROJECT_SECRET_KEY=  # совпадает с LANGFUSE_SECRET_KEY
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=change-me

# Сгенерируй: python3 -c "import secrets; print(secrets.token_hex(32))"
NEXTAUTH_SECRET=change-me-to-a-random-32-char-secret
NEXTAUTH_URL=http://localhost:3000
SALT=change-me-to-a-random-32-char-salt
# Сгенерируй: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change-me-to-a-random-64-char-hex

# Пароли БД и ClickHouse (внутренние, не менять после первого запуска)
LANGFUSE_POSTGRES_PASSWORD=changeme
LANGFUSE_CLICKHOUSE_PASSWORD=changeme
