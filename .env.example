# =============================================================================
# ChemCrow2 — Environment Configuration
# =============================================================================
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env
#
# Для ЛОКАЛЬНОЙ разработки (с Docker и без) значения по умолчанию уже подходят.
# Для PRODUCTION — замени помеченные строки на реальные данные.
# =============================================================================

# -- Общее --
PROJECT_NAME="ChemCrow2"
STACK_NAME=chemcrow2

# local | staging | production
ENVIRONMENT=local

# -- Домен и фронтенд --
# Локально: localhost
# Production: IP сервера или домен (например, 123.45.67.89)
DOMAIN=localhost

# Локально: http://localhost:5173 (Docker) или http://localhost:5173 (Vite dev)
# Production: http://<IP_СЕРВЕРА>
FRONTEND_HOST=http://localhost:5173

# -- CORS --
# Локально: все localhost-ы
# Production: http://<IP_СЕРВЕРА>
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:8000"

# -- Безопасность --
# Сгенерируй: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change_me

# -- PostgreSQL --
# Без Docker: localhost
# С Docker: не важно, compose переопределяет на "db"
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# -- Redis --
# Без Docker: localhost
# С Docker: не важно, compose переопределяет на "redis://redis:6379/0"
REDIS_URL=redis://localhost:6379/0

# -- Email (опционально) --
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# -- Мониторинг (опционально) --
SENTRY_DSN=

# -- LLM / AI Agent --
# Провайдер по умолчанию: openai | anthropic
DEFAULT_LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
# Кастомный base URL (для совместимых прокси, Azure и т.д.). Оставь пустым для api.openai.com
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Кастомный base URL. Оставь пустым для api.anthropic.com
ANTHROPIC_BASE_URL=

# -- AI Agent: Optional Tool API Keys --
SERP_API_KEY=
CHEMSPACE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# -- AiZynthFinder --
AZF_CONFIG_PATH=data/aizynthfinder/config.yml

# -- Docker-образы --
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
